# Stage 1: Build dependencies (Root-owned during build)
FROM python:3.11-slim as builder

WORKDIR /build

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

ENV VIRTUAL_ENV=/opt/venv/nexus-env
RUN python3 -m venv $VIRTUAL_ENV
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

COPY modules/nexus-nucleus/docker/dev/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Stage 2: Final Runtime (User-owned for Development)
FROM python:3.11-slim

# 1. Setup 'ubuntu' user, sudo, and dev tools
RUN set -eux; \
    apt-get update && apt-get install -y --no-install-recommends \
    sudo \
    libpq-dev \
    micro \
    tmux \
    curl; \
    # Ensure ubuntu user exists
    getent passwd ubuntu >/dev/null 2>&1 || adduser --disabled-password --gecos '' ubuntu; \
    usermod -aG sudo ubuntu; \
    # Grant passwordless sudo for dev convenience
    echo "ubuntu ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers; \
    # Pre-create the target directories
    mkdir -p /nexus-nucleus /opt/venv/nexus-env; \
    rm -rf /var/lib/apt/lists/*

# 2. Copy the Venv and SET OWNERSHIP to ubuntu
COPY --from=builder --chown=ubuntu:ubuntu /opt/venv/nexus-env /opt/venv/nexus-env

# 3. Final Permissions: Hand over the workspace and venv to ubuntu
RUN chown -R ubuntu:ubuntu /nexus-nucleus /opt/venv/nexus-env

# 4. Environment & Workspace
ENV VIRTUAL_ENV=/opt/venv/nexus-env
ENV PATH="$VIRTUAL_ENV/bin:$PATH"
ENV PYTHONPATH=/nexus-nucleus

WORKDIR /nexus-nucleus
USER ubuntu

# Stay alive for manual interaction/debugging
